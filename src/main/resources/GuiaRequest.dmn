<?xml version="1.0" encoding="UTF-8"?>
<dmn:definitions xmlns:dmn="http://www.omg.org/spec/DMN/20180521/MODEL/"
                 xmlns:dmndi="http://www.omg.org/spec/DMN/20180521/DMNDI/"
                 xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
                 xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
                 id="GuiaRequestDMN"
                 name="Guia Request Decision"
                 namespace="https://kie.org/dmn/tiss">

    <!-- Input: tipoGuia -->
    <dmn:inputData id="InputTipoGuia" name="tipoGuia">
        <dmn:variable id="VarTipoGuia" name="tipoGuia" typeRef="string"/>
    </dmn:inputData>

    <!-- Input: urgencia -->
    <dmn:inputData id="InputUrgencia" name="urgencia">
        <dmn:variable id="VarUrgencia" name="urgencia" typeRef="boolean"/>
    </dmn:inputData>

    <!-- Input: codigoProcedimento -->
    <dmn:inputData id="InputCodigoProcedimento" name="codigoProcedimento">
        <dmn:variable id="VarCodigoProcedimento" name="codigoProcedimento" typeRef="string"/>
    </dmn:inputData>

    <!-- Decision: Validar Guia -->
    <dmn:decision id="DecisionValidarGuia" name="Validar Guia">
        <dmn:variable name="resultado" typeRef="string"/>
        <dmn:informationRequirement>
            <dmn:requiredInput href="#InputTipoGuia"/>
        </dmn:informationRequirement>
        <dmn:informationRequirement>
            <dmn:requiredInput href="#InputUrgencia"/>
        </dmn:informationRequirement>
        <dmn:informationRequirement>
            <dmn:requiredInput href="#InputCodigoProcedimento"/>
        </dmn:informationRequirement>
        <dmn:decisionTable id="DecisionTableValidarGuia" hitPolicy="FIRST">
            <dmn:input id="InputCol1">
                <dmn:inputExpression typeRef="string">
                    <dmn:text>tipoGuia</dmn:text>
                </dmn:inputExpression>
            </dmn:input>
            <dmn:input id="InputCol2">
                <dmn:inputExpression typeRef="boolean">
                    <dmn:text>urgencia</dmn:text>
                </dmn:inputExpression>
            </dmn:input>
            <dmn:input id="InputCol3">
                <dmn:inputExpression typeRef="string">
                    <dmn:text>codigoProcedimento</dmn:text>
                </dmn:inputExpression>
            </dmn:input>
            <dmn:output id="OutputCol1" name="resultado" typeRef="string"/>

            <!-- Regra 1: Consulta Urgente -->
            <dmn:rule id="Rule1">
                <dmn:inputEntry>
                    <dmn:text>"CONSULTA"</dmn:text>
                </dmn:inputEntry>
                <dmn:inputEntry>
                    <dmn:text>true</dmn:text>
                </dmn:inputEntry>
                <dmn:inputEntry>
                    <dmn:text>-</dmn:text>
                </dmn:inputEntry>
                <dmn:outputEntry>
                    <dmn:text>"Guia de consulta urgente aprovada"</dmn:text>
                </dmn:outputEntry>
            </dmn:rule>

            <!-- Regra 2: Consulta Normal -->
            <dmn:rule id="Rule2">
                <dmn:inputEntry>
                    <dmn:text>"CONSULTA"</dmn:text>
                </dmn:inputEntry>
                <dmn:inputEntry>
                    <dmn:text>false</dmn:text>
                </dmn:inputEntry>
                <dmn:inputEntry>
                    <dmn:text>-</dmn:text>
                </dmn:inputEntry>
                <dmn:outputEntry>
                    <dmn:text>"Guia de consulta normal aprovada"</dmn:text>
                </dmn:outputEntry>
            </dmn:rule>

            <!-- Regra 3: SADT Urgente -->
            <dmn:rule id="Rule3">
                <dmn:inputEntry>
                    <dmn:text>"SADT"</dmn:text>
                </dmn:inputEntry>
                <dmn:inputEntry>
                    <dmn:text>true</dmn:text>
                </dmn:inputEntry>
                <dmn:inputEntry>
                    <dmn:text>-</dmn:text>
                </dmn:inputEntry>
                <dmn:outputEntry>
                    <dmn:text>"SADT urgente - requer autorização imediata"</dmn:text>
                </dmn:outputEntry>
            </dmn:rule>

            <!-- Regra 4: SADT Normal -->
            <dmn:rule id="Rule4">
                <dmn:inputEntry>
                    <dmn:text>"SADT"</dmn:text>
                </dmn:inputEntry>
                <dmn:inputEntry>
                    <dmn:text>false</dmn:text>
                </dmn:inputEntry>
                <dmn:inputEntry>
                    <dmn:text>-</dmn:text>
                </dmn:inputEntry>
                <dmn:outputEntry>
                    <dmn:text>"SADT normal - prazo de 48h para autorização"</dmn:text>
                </dmn:outputEntry>
            </dmn:rule>

            <!-- Regra 5: Internação -->
            <dmn:rule id="Rule5">
                <dmn:inputEntry>
                    <dmn:text>"INTERNACAO"</dmn:text>
                </dmn:inputEntry>
                <dmn:inputEntry>
                    <dmn:text>-</dmn:text>
                </dmn:inputEntry>
                <dmn:inputEntry>
                    <dmn:text>-</dmn:text>
                </dmn:inputEntry>
                <dmn:outputEntry>
                    <dmn:text>"Guia de internação - requer análise médica"</dmn:text>
                </dmn:outputEntry>
            </dmn:rule>

            <!-- Regra 6: Procedimento específico -->
            <dmn:rule id="Rule6">
                <dmn:inputEntry>
                    <dmn:text>-</dmn:text>
                </dmn:inputEntry>
                <dmn:inputEntry>
                    <dmn:text>-</dmn:text>
                </dmn:inputEntry>
                <dmn:inputEntry>
                    <dmn:text>"10101012"</dmn:text>
                </dmn:inputEntry>
                <dmn:outputEntry>
                    <dmn:text>"Procedimento 10101012 - Consulta em consultório"</dmn:text>
                </dmn:outputEntry>
            </dmn:rule>

            <!-- Regra Default -->
            <dmn:rule id="RuleDefault">
                <dmn:inputEntry>
                    <dmn:text>-</dmn:text>
                </dmn:inputEntry>
                <dmn:inputEntry>
                    <dmn:text>-</dmn:text>
                </dmn:inputEntry>
                <dmn:inputEntry>
                    <dmn:text>-</dmn:text>
                </dmn:inputEntry>
                <dmn:outputEntry>
                    <dmn:text>"Tipo de guia não reconhecido"</dmn:text>
                </dmn:outputEntry>
            </dmn:rule>
        </dmn:decisionTable>
    </dmn:decision>

    <!-- Decision: Calcular Valor -->
    <dmn:decision id="DecisionCalcularValor" name="Calcular Valor">
        <dmn:variable name="valor" typeRef="number"/>
        <dmn:informationRequirement>
            <dmn:requiredInput href="#InputTipoGuia"/>
        </dmn:informationRequirement>
        <dmn:informationRequirement>
            <dmn:requiredInput href="#InputUrgencia"/>
        </dmn:informationRequirement>
        <dmn:decisionTable id="DecisionTableCalcularValor" hitPolicy="FIRST">
            <dmn:input id="InputCol1Valor" label="tipoGuia">
                <dmn:inputExpression typeRef="string">
                    <dmn:text>tipoGuia</dmn:text>
                </dmn:inputExpression>
            </dmn:input>
            <dmn:input id="InputCol2Valor" label="urgencia">
                <dmn:inputExpression typeRef="boolean">
                    <dmn:text>urgencia</dmn:text>
                </dmn:inputExpression>
            </dmn:input>
            <dmn:output id="OutputCol1Valor" name="valor" typeRef="number"/>

            <dmn:rule id="RuleValor1" label="Consulta Urgente">
                <dmn:inputEntry>
                    <dmn:text>"CONSULTA"</dmn:text>
                </dmn:inputEntry>
                <dmn:inputEntry>
                    <dmn:text>true</dmn:text>
                </dmn:inputEntry>
                <dmn:outputEntry>
                    <dmn:text>250</dmn:text>
                </dmn:outputEntry>
            </dmn:rule>

            <dmn:rule id="RuleValor2">
                <dmn:inputEntry>
                    <dmn:text>"CONSULTA"</dmn:text>
                </dmn:inputEntry>
                <dmn:inputEntry>
                    <dmn:text>false</dmn:text>
                </dmn:inputEntry>
                <dmn:outputEntry>
                    <dmn:text>150</dmn:text>
                </dmn:outputEntry>
            </dmn:rule>

            <dmn:rule id="RuleValor3">
                <dmn:inputEntry>
                    <dmn:text>"SADT"</dmn:text>
                </dmn:inputEntry>
                <dmn:inputEntry>
                    <dmn:text>true</dmn:text>
                </dmn:inputEntry>
                <dmn:outputEntry>
                    <dmn:text>500</dmn:text>
                </dmn:outputEntry>
            </dmn:rule>

            <dmn:rule id="RuleValor4">
                <dmn:inputEntry>
                    <dmn:text>"SADT"</dmn:text>
                </dmn:inputEntry>
                <dmn:inputEntry>
                    <dmn:text>false</dmn:text>
                </dmn:inputEntry>
                <dmn:outputEntry>
                    <dmn:text>300</dmn:text>
                </dmn:outputEntry>
            </dmn:rule>

            <dmn:rule id="RuleValorDefault">
                <dmn:inputEntry>
                    <dmn:text>-</dmn:text>
                </dmn:inputEntry>
                <dmn:inputEntry>
                    <dmn:text>-</dmn:text>
                </dmn:inputEntry>
                <dmn:outputEntry>
                    <dmn:text>0</dmn:text>
                </dmn:outputEntry>
            </dmn:rule>
        </dmn:decisionTable>
    </dmn:decision>

</dmn:definitions>
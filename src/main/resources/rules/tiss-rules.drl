package io.trustep.rules

import io.trustep.dto.ContaFato;
import io.trustep.dto.Elegibilidade;
import io.trustep.dto.Autorizacao;
import io.trustep.dto.Glosa;

// ─────────────────────────────────────────────────────────────────────────────
// ELEGIBILIDADE (Etapa 4 – spec §4: "Validar Elegibilidade do Beneficiário")
// ─────────────────────────────────────────────────────────────────────────────

// Regra: atendimento coberto por RN da ANS → elegível automaticamente
rule "Elegibilidade - atendimento RN"
    when
        $fato : ContaFato(atendimentoRN == true)
        $e    : Elegibilidade(elegivel == false)
    then
        modify($e){
            setElegivel(true),
            setMensagem("Beneficiário elegível por Resolução Normativa (ANS)")
        };
end

// Regra: padrão — sem RN o beneficiário ainda é elegível (simplificação;
//        num sistema real consultaria cadastro de elegibilidade)
rule "Elegibilidade - padrao"
    when
        $fato : ContaFato(atendimentoRN == false)
        $e    : Elegibilidade(elegivel == false)
    then
        modify($e){
            setElegivel(true),
            setMensagem("Beneficiário elegível")
        };
end

// ─────────────────────────────────────────────────────────────────────────────
// AUTORIZAÇÃO (Etapa 4 – spec §4: "Verificar Necessidade de Autorização")
// ─────────────────────────────────────────────────────────────────────────────

// Regra: INTERNACAO exige autorização prévia
rule "Autorizacao - internacao"
    when
        $fato : ContaFato(tipoGuia == "INTERNACAO")
        $a    : Autorizacao(necessitaAutorizacao == false)
    then
        modify($a){
            setNecessitaAutorizacao(true),
            setTipoAutorizacao("Autorização para internação")
        };
end

// Regra: OPME exige autorização prévia
rule "Autorizacao - opme"
    when
        $fato : ContaFato(tipoGuia == "OPME")
        $a    : Autorizacao(necessitaAutorizacao == false)
    then
        modify($a){
            setNecessitaAutorizacao(true),
            setTipoAutorizacao("Autorização para OPME")
        };
end

// ─────────────────────────────────────────────────────────────────────────────
// GLOSA (Etapa 4 – spec §4: "Processar Glosa")
// ─────────────────────────────────────────────────────────────────────────────

// Regra: glosa parcial — reduz 50% do valor (spec ex: R$10.000 → R$5.000)
rule "Glosa - parcial"
    when
        $fato : ContaFato(possuiGlosa == true, valorGuia != null)
        $g    : Glosa(statusGlosa == "SEM_GLOSA")
    then
            // Abordagem purista do Java, mas isolada dentro do bloco then
            java.math.BigDecimal desconto = $fato.getValorGuia().multiply(new java.math.BigDecimal("0.50"));
            java.math.BigDecimal valorFinal = $fato.getValorGuia().subtract(desconto);
            String tipo = $fato.getTipoGlosa() != null ? $fato.getTipoGlosa() : "GLOSA_PARCIAL";

            modify($g) {
                setStatusGlosa("GLOSADO"),
                setPermiteRecurso(true),
                setValorLiberado(valorFinal),
                setTipoGlosa(tipo),
                setValorAprovado(valorFinal)
            };
    end

// Regra: sem glosa — valor liberado é o valor integral da guia
rule "Glosa - sem glosa"
    when
        $fato : ContaFato(possuiGlosa == false, valorGuia != null)
        $g    : Glosa(statusGlosa == "SEM_GLOSA")
    then
        modify($g){
            setValorLiberado($fato.getValorGuia()),
            setValorAprovado($fato.getValorGuia())
        };
end
